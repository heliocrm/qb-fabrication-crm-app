# Supabase — QB Fabrication CRM
# Project: https://supabase.com/dashboard/project/wkutsmgonkawgbidinwx

# Get these from: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Public site URL for auth redirects (OAuth, email confirmation)
# Local dev: http://localhost:3000  |  Production: https://crmv1.qbfab.com
# Pull soft-launch Vercel project: https://pull.qbfab.com
# Must match Supabase Auth → URL Configuration (see below).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Material Pull standalone soft-launch ───────────────────────────────────
# On a separate Vercel project (same repo), set:
#   NEXT_PUBLIC_APP_MODE=pull
#   NEXT_PUBLIC_SITE_URL=https://pull.qbfab.com
# This hides CRM links and middleware-locks navigation to /pull + /auth.
# NEXT_PUBLIC_APP_MODE=pull
#
# Or allowlist hosts on a shared deploy (comma-separated hostnames):
# NEXT_PUBLIC_PULL_APP_HOSTS=pull.qbfab.com
#
# Supabase Auth → Redirect URLs (add for the pull domain):
#   https://pull.qbfab.com/auth/callback
#   https://pull.qbfab.com/auth/reset-password
#   https://pull.qbfab.com/**

# ─── Traveler standalone soft-launch ────────────────────────────────────────
# Separate Vercel project (same repo):
#   NEXT_PUBLIC_APP_MODE=traveler
#   NEXT_PUBLIC_SITE_URL=https://traveler.qbfab.com
# Middleware locks navigation to /traveler + /auth. Manifest: /traveler.webmanifest
# NEXT_PUBLIC_APP_MODE=traveler
#
# Or allowlist hosts on a shared deploy:
# NEXT_PUBLIC_TRAVELER_APP_HOSTS=traveler.qbfab.com
#
# Supabase Auth → Redirect URLs:
#   https://traveler.qbfab.com/auth/callback
#   https://traveler.qbfab.com/auth/reset-password
#   https://traveler.qbfab.com/**
# Do not set APP_MODE=pull and APP_MODE=traveler on the same deploy.

# ─── Supabase Google sign-in (Auth provider) ───────────────────────────────
# Separate from the Drive service account below. Enable in Supabase Dashboard
# → Authentication → Providers → Google, then create a "Web application" OAuth
# client in Google Cloud Console (APIs & Services → Credentials).
#
# Google Cloud Console → Authorized redirect URIs (required — same for local
# and production when using one Supabase project):
#   https://wkutsmgonkawgbidinwx.supabase.co/auth/v1/callback
#
# Google Cloud Console → Authorized JavaScript origins (recommended):
#   https://wkutsmgonkawgbidinwx.supabase.co
#
# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: https://crmv1.qbfab.com  ← required for password reset & invite emails
#   Redirect URLs (add both):
#     http://localhost:3000/auth/callback
#     https://crmv1.qbfab.com/auth/callback
#     https://crmv1.qbfab.com/auth/reset-password
#   (Wildcards also work, e.g. https://crmv1.qbfab.com/**)
#
# Paste the Google OAuth Client ID + Secret into Supabase → Providers → Google.

# Required for `pnpm seed` — Supabase Dashboard → Settings → API → service_role (keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Resend (team invite emails) ────────────────────────────────────────────
# API key from https://resend.com/api-keys — updates.qbfab.com must be verified in Resend.
# Place Resend vars BEFORE multiline Google keys in .env.local (broken quoted keys block later lines).
RESEND_API_KEY=re_your_api_key_here
# Optional override (default: QB Fabrication <invites@updates.qbfab.com>)
# RESEND_FROM_EMAIL=invites@updates.qbfab.com

# ─── Web Push (Material Pull PWA notifications) ─────────────────────────────
# Generate once: npx web-push generate-vapid-keys
# Public key is safe in the browser; keep private key secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BBufQMJgEsfiMG7bRv6rzCENxjzgTuoxd4LSaTBCCL8goti07oSsHOEEv32QMjQhz1ObhBrrSs9528j-1_AnmTQ
VAPID_PRIVATE_KEY=your-YnPU5CnLGgpNu-9QST10B0LtEnCIKOcR1oAhza2o9Ag
VAPID_SUBJECT=mailto:dylan@qbfab.com

# ─── Google Workspace (Drive) ───────────────────────────────────────────────
# Option A: individual env vars (paste private key with literal \n for newlines)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=crm-drive@your-project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_DRIVE_JOBS_ROOT_FOLDER_ID=your-root-folder-id
# GOOGLE_WORKSPACE_IMPERSONATE_EMAIL=you@qbfab.com
# GOOGLE_WORKSPACE_DOMAIN=qbfab.com

# Option B: full JSON (recommended for Vercel)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# OAuth2 (future — user-delegated Calendar/Gmail)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://crmv1.qbfab.com/api/google/oauth/callback
