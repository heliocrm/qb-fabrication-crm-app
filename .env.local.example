# Supabase — QB Fabrication CRM
# Project: https://supabase.com/dashboard/project/wkutsmgonkawgbidinwx

# Get these from: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Public site URL for auth redirects (OAuth, email confirmation)
# Also set Site URL + Redirect URLs in Supabase Auth settings to match.
# Local dev: http://localhost:3000  |  Production: https://crmv1.qbfab.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for `pnpm seed` — Supabase Dashboard → Settings → API → service_role (keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Google Workspace (Drive) ───────────────────────────────────────────────
# Option A: individual env vars (paste private key with literal \n for newlines)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=crm-drive@your-project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_DRIVE_JOBS_ROOT_FOLDER_ID=your-root-folder-id
# GOOGLE_WORKSPACE_IMPERSONATE_EMAIL=you@qbfab.com
# GOOGLE_WORKSPACE_DOMAIN=qbfab.com

# Option B: full JSON (recommended for Vercel)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# OAuth2 (future — user-delegated Calendar/Gmail)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://crmv1.qbfab.com/api/google/oauth/callback
